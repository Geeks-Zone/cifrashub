# ============================================================
# CifrasHub — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ----------------------------------------------------------
# Database (Neon PostgreSQL)
# Get your connection strings at https://console.neon.tech
# ----------------------------------------------------------
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host/database?sslmode=require

# ----------------------------------------------------------
# Authentication (Neon Auth / Better Auth)
# Generate a strong secret: openssl rand -base64 32
# ----------------------------------------------------------
AUTH_COOKIE_SECRET=your-super-secret-cookie-key-here

# Neon Auth project URL (if using Neon's built-in auth)
NEON_AUTH_URL=https://your-neon-auth-url.neon.tech

# ----------------------------------------------------------
# App
# ----------------------------------------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:3000
