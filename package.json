{
  "name": "cifrashub",
  "version": "0.1.0",
  "description": "Chord sheet visualizer for any chordal instrument — guitar, bass, ukulele, keyboard and more — with folders, transposition, metronome, tuner, setlists, and stage mode.",
  "license": "MIT",
  "author": "CifrasHub Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/Geeks-Zone/cifrashub.git"
  },
  "homepage": "https://cifrashub.app",
  "bugs": {
    "url": "https://github.com/Geeks-Zone/cifrashub/issues"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "node scripts/vercel-build.cjs",
    "start": "next start",
    "lint": "eslint",
    "db:push": "drizzle-kit push",
    "db:push:ci": "drizzle-kit push --force",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@neondatabase/neon-js": "^0.2.0-beta.1",
    "@neondatabase/serverless": "^1.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "overrides": {
    "better-auth": "1.6.0",
    "esbuild": "^0.25.4",
    "fastify": "5.8.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv": "^17.4.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "postcss": "^8.5.9",
    "shadcn": "^4.1.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "knip": {
    "entry": [
      "scripts/migrate.cjs"
    ],
    "ignoreIssues": {
      "src/components/ui/**/*.tsx": [
        "exports",
        "types"
      ]
    }
  }
}
