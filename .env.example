# ============================================================
# CifrasHub — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ----------------------------------------------------------
# Database (Neon PostgreSQL)
# Get your connection strings at https://console.neon.tech
# ----------------------------------------------------------
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host/database?sslmode=require

# ----------------------------------------------------------
# Authentication (Neon Auth v0.2 / Better Auth)
# The Neon/Vercel integration sets these automatically.
# For manual setup, get the URL at https://console.neon.tech (Auth section).
# Generate a strong secret: openssl rand -base64 32
# ----------------------------------------------------------

# Neon Auth project URL — formato esperado:
# https://ep-xxx.neonauth.us-east-1.aws.neon.tech/neondb/auth
NEON_AUTH_BASE_URL=https://ep-xxx.neonauth.us-east-1.aws.neon.tech/neondb/auth

# Cookie secret para assinar a sessão (mínimo 32 caracteres)
NEON_AUTH_COOKIE_SECRET=your-super-secret-cookie-key-min-32-chars

# Variáveis legadas (mantidas por compatibilidade — prefira as acima)
# NEON_AUTH_URL=https://your-neon-auth-url.neon.tech
# AUTH_COOKIE_SECRET=your-super-secret-cookie-key-here

# ----------------------------------------------------------
# App
# ----------------------------------------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:3000
